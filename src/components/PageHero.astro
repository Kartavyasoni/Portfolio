---
import Container from '@/components/ui/Container.astro';

interface Props {
  kicker?: string;
  title: string;
  intro?: string;
  class?: string;
}

const { kicker, title, intro, class: className } = Astro.props;
---

<header class={`relative overflow-hidden pt-36 pb-16 sm:pt-44 sm:pb-20 ${className ?? ''}`}>
  <div
    class="glow-halo pointer-events-none absolute -top-1/3 left-1/4 size-[40vw] max-w-xl opacity-40"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-b from-transparent to-[var(--bg)]"
  >
  </div>

  <Container class="relative">
    <div class="max-w-3xl" data-hero>
      {kicker && <span class="kicker" data-hero-item>{kicker}</span>}
      <h1
        class="mt-4 text-[clamp(2.25rem,5.5vw,4rem)] font-semibold leading-[1.05]"
        data-hero-item
      >
        {title}
      </h1>
      {
        intro && (
          <p class="mt-5 max-w-2xl text-lg text-muted" data-hero-item>
            {intro}
          </p>
        )
      }
      <slot />
    </div>
  </Container>
</header>
