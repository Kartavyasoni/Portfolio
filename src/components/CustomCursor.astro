---
/**
 * Custom glowing cursor — a blue orb that follows the pointer with a soft glow.
 * Only active on devices with a fine pointer + hover (desktop); touch devices
 * keep the native behavior. Hides the native cursor while active.
 */
---

<div id="cursor" aria-hidden="true"></div>

<style is:global>
  @media (hover: hover) and (pointer: fine) {
    /* Hide the native arrow everywhere; the orb replaces it. */
    * {
      cursor: none !important;
    }

    #cursor {
      position: fixed;
      top: 0;
      left: 0;
      width: 20px;
      height: 20px;
      border-radius: 9999px;
      background: radial-gradient(circle at 50% 42%, #d4f3ff 0%, #38bdf8 55%, #22d3ee 100%);
      box-shadow:
        0 0 8px 1px rgba(56, 189, 248, 0.8),
        0 0 20px 6px rgba(34, 211, 238, 0.35),
        0 0 34px 12px rgba(46, 124, 246, 0.18);
      pointer-events: none;
      z-index: 9999;
      opacity: 0;
      transform: translate3d(-100px, -100px, 0) translate(-50%, -50%);
      transition:
        opacity 0.25s ease,
        width 0.22s ease,
        height 0.22s ease,
        background 0.22s ease;
      will-change: transform;
    }

    #cursor.is-visible {
      opacity: 1;
    }

    /* Softer, larger ring when hovering interactive elements */
    #cursor.is-interactive {
      width: 38px;
      height: 38px;
      background: radial-gradient(
        circle,
        rgba(125, 211, 252, 0.45) 0%,
        rgba(56, 189, 248, 0.12) 70%
      );
    }

    #cursor.is-down {
      width: 14px;
      height: 14px;
    }
  }
</style>

<script>
  const fine = window.matchMedia('(hover: hover) and (pointer: fine)');

  if (fine.matches) {
    const cursor = document.getElementById('cursor');
    if (cursor) {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const ease = reduce ? 1 : 0.2;
      let tx = 0;
      let ty = 0;
      let x = 0;
      let y = 0;
      let visible = false;

      window.addEventListener(
        'mousemove',
        (e) => {
          tx = e.clientX;
          ty = e.clientY;
          if (!visible) {
            visible = true;
            x = tx;
            y = ty;
            cursor.classList.add('is-visible');
          }
        },
        { passive: true },
      );

      document.addEventListener('mouseleave', () => cursor.classList.remove('is-visible'));
      document.addEventListener('mouseenter', () => {
        if (visible) cursor.classList.add('is-visible');
      });
      window.addEventListener('mousedown', () => cursor.classList.add('is-down'));
      window.addEventListener('mouseup', () => cursor.classList.remove('is-down'));

      // Grow over interactive targets.
      const sel = 'a, button, [role="button"], input, textarea, select, label, summary, [data-glow]';
      document.addEventListener('mouseover', (e) => {
        if (e.target instanceof Element && e.target.closest(sel)) {
          cursor.classList.add('is-interactive');
        }
      });
      document.addEventListener('mouseout', (e) => {
        if (e.target instanceof Element && e.target.closest(sel)) {
          const to = e.relatedTarget;
          if (!(to instanceof Element) || !to.closest(sel)) {
            cursor.classList.remove('is-interactive');
          }
        }
      });

      const lerp = (a: number, b: number, n: number) => a + (b - a) * n;
      const tick = () => {
        x = lerp(x, tx, ease);
        y = lerp(y, ty, ease);
        cursor.style.transform = `translate3d(${x}px, ${y}px, 0) translate(-50%, -50%)`;
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }
  }
</script>
