---
import { navItems, site, socials } from '@/lib/site';
import Container from '@/components/ui/Container.astro';
import Icon from '@/components/ui/Icon.astro';

const year = new Date().getFullYear();
---

<footer class="relative mt-20 border-t border-border bg-surface/40">
  <Container class="relative py-14">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <a href="/" class="flex items-center gap-2.5 font-display text-lg font-semibold">
          <span
            class="grid size-8 place-items-center rounded-lg border border-accent/30 bg-accent/10 font-mono text-sm text-accent"
          >
            {site.brand}
          </span>
          {site.name}
        </a>
        <p class="mt-4 text-balance text-sm text-muted">
          Let’s build intelligent systems that create measurable impact.
        </p>
        <div class="mt-5 flex items-center gap-2">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target={s.icon === 'email' ? undefined : '_blank'}
                rel="noopener noreferrer"
                aria-label={s.label}
                class="grid size-9 place-items-center rounded-lg border border-border bg-surface-2 text-muted transition-colors hover:border-accent/40 hover:text-accent"
              >
                <Icon name={s.icon} class="size-4" />
              </a>
            ))
          }
        </div>
      </div>

      <nav class="flex flex-col gap-3">
        <span class="kicker">Navigate</span>
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-sm text-muted transition-colors hover:text-text"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-border pt-6 text-xs text-faint sm:flex-row"
    >
      <p>© {year} {site.name}. All rights reserved.</p>
      <p class="font-mono">Built with Astro · Three.js · GSAP</p>
    </div>
  </Container>
</footer>
