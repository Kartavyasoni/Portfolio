---
import Icon from '@/components/ui/Icon.astro';
---

<button
  type="button"
  id="theme-toggle"
  class="group relative grid size-9 place-items-center overflow-hidden rounded-lg border border-border bg-surface-2 text-muted transition-colors hover:border-border-strong hover:text-text"
  aria-label="Toggle color theme"
>
  <!-- Sun shows in dark mode (click → light); moon shows in light mode. -->
  <Icon
    name="sun"
    class="size-4 transition-all duration-300 light:rotate-90 light:scale-0"
  />
  <Icon
    name="moon"
    class="absolute size-4 rotate-90 scale-0 transition-all duration-300 light:rotate-0 light:scale-100"
  />
</button>

<script is:inline>
  (() => {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const next = root.dataset.theme === 'light' ? 'dark' : 'light';
      root.dataset.theme = next;
      localStorage.setItem('theme', next);
    });
  })();
</script>
