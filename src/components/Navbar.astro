---
import { navItems, site } from '@/lib/site';
import Icon from '@/components/ui/Icon.astro';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header
  id="navbar"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-scrolled="false"
>
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-5 sm:px-8">
    <!-- Brand wordmark -->
    <a
      href="/"
      class="group font-display text-lg font-bold tracking-tight sm:text-xl"
      aria-label={`${site.name} — home`}
    >
      Kartavya <span class="text-gradient">Soni</span>
    </a>

    <!-- Desktop nav -->
    <div
      class="glass absolute left-1/2 hidden -translate-x-1/2 items-center gap-1 rounded-full px-2 py-1.5 md:flex"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-full px-4 py-1.5 text-sm transition-colors',
              isActive(item.href)
                ? 'bg-surface-3 text-text'
                : 'text-muted hover:text-text',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <!-- Right cluster -->
    <div class="flex items-center gap-2">
      <a
        href={site.resume}
        download
        class="group/btn inline-flex h-10 items-center justify-center gap-2 rounded-full bg-gradient-to-r from-brand-600 to-brand-400 px-4 text-sm font-semibold text-white shadow-[0_8px_30px_-8px_var(--glow)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_40px_-6px_var(--glow)] sm:px-5"
      >
        <Icon name="download" class="size-4 transition-transform duration-300 group-hover/btn:translate-y-0.5" />
        <span class="hidden sm:inline">Download Resume</span>
        <span class="sm:hidden">Resume</span>
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="grid size-10 place-items-center rounded-lg border border-border bg-surface-2 text-muted transition-colors hover:text-text md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" class="size-4" />
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="glass hidden border-t border-border md:hidden">
    <div class="flex flex-col gap-1 px-5 py-4">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-4 py-3 text-sm transition-colors',
              isActive(item.href)
                ? 'bg-surface-3 text-text'
                : 'text-muted hover:bg-surface-2 hover:text-text',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  // Solidify the navbar background after scrolling past the hero fold.
  const navbar = document.getElementById('navbar');
  const onScroll = () => {
    navbar?.setAttribute('data-scrolled', String(window.scrollY > 24));
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile menu toggle.
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  menuToggle?.addEventListener('click', () => {
    const open = mobileMenu?.classList.toggle('hidden') === false;
    menuToggle.setAttribute('aria-expanded', String(open));
  });
</script>

<style>
  #navbar[data-scrolled='true'] nav {
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
</style>
