---
import Container from '@/components/ui/Container.astro';

interface Props {
  id?: string;
  /** Kicker label (mono eyebrow) above the heading. */
  kicker?: string;
  title?: string;
  /** Supporting copy under the heading. */
  intro?: string;
  align?: 'left' | 'center';
  container?: 'default' | 'narrow' | 'wide';
  /** Max-width utility for the header block (default max-w-2xl). */
  headerWidth?: string;
  class?: string;
}

const {
  id,
  kicker,
  title,
  intro,
  align = 'left',
  container = 'default',
  headerWidth = 'max-w-2xl',
  class: className,
} = Astro.props;

const hasHeader = kicker || title || intro;
const alignCls = align === 'center' ? 'text-center mx-auto items-center' : '';
---

<section id={id} class={`relative py-20 sm:py-28 ${className ?? ''}`}>
  <Container size={container}>
    {
      hasHeader && (
        <header class={`flex ${headerWidth} flex-col gap-4 ${alignCls}`} data-reveal>
          {kicker && <span class="kicker">{kicker}</span>}
          {title && (
            <h2 class="text-3xl font-semibold sm:text-4xl md:text-5xl">{title}</h2>
          )}
          {intro && <p class="text-balance text-base text-muted sm:text-lg">{intro}</p>}
        </header>
      )
    }
    <slot />
  </Container>
</section>
