---
interface Props {
  variant?: 'default' | 'accent' | 'outline';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;

const variants = {
  default: 'bg-surface-3 text-muted border border-border',
  accent: 'bg-accent/10 text-accent border border-accent/20',
  outline: 'border border-border-strong text-muted',
};
---

<span
  class={`inline-flex items-center rounded-full px-2.5 py-1 font-mono text-xs tracking-wide ${variants[variant]} ${className ?? ''}`}
>
  <slot />
</span>
