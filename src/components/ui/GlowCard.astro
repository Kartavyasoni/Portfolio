---
/**
 * Surface card with a cursor-following spotlight + glow border.
 * The spotlight position is written to CSS vars (--mx, --my) on hover.
 */
interface Props {
  href?: string;
  class?: string;
  /** Disable the lift-on-hover translate (e.g. for large feature cards). */
  noLift?: boolean;
  /** On hover, use a bold accent (blue) border instead of the subtle one. */
  accentHover?: boolean;
}

const {
  href,
  class: className,
  noLift = false,
  accentHover = false,
} = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  data-glow
  class:list={[
    'group/glow relative block overflow-hidden rounded-[var(--radius-card)] border border-border bg-surface-2/50 p-6 transition-all duration-500 ease-[var(--ease-out-expo)]',
    accentHover
      ? 'hover:border-accent hover:ring-1 hover:ring-accent'
      : 'hover:border-border-strong',
    !noLift && 'hover:-translate-y-1',
    className,
  ]}
>
  <!-- Spotlight layer -->
  <div
    class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-500 group-hover/glow:opacity-100"
    style="background: radial-gradient(380px circle at var(--mx) var(--my), color-mix(in srgb, var(--accent) 14%, transparent), transparent 60%)"
    aria-hidden="true"
  >
  </div>
  <!-- Content -->
  <div class="relative z-10">
    <slot />
  </div>
</Tag>

<script>
  const cards = document.querySelectorAll<HTMLElement>('[data-glow]');
  cards.forEach((card) => {
    card.addEventListener('pointermove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
      card.style.setProperty('--my', `${e.clientY - rect.top}px`);
    });
  });
</script>
