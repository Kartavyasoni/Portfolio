---
import Section from '@/components/ui/Section.astro';
import GlowCard from '@/components/ui/GlowCard.astro';
import { expertise } from '@/data/expertise';

// Minimal line glyphs per domain (stroke-based, inherit currentColor).
const glyphs: Record<string, string> = {
  // Pipeline — flowing path between nodes
  pipeline:
    '<path d="M3 7h6a3 3 0 0 1 3 3v4a3 3 0 0 0 3 3h6M3 17h6" stroke-width="1.6"/><circle cx="3" cy="7" r="1.6" stroke-width="1.6"/><circle cx="21" cy="17" r="1.6" stroke-width="1.6"/>',
  // Distributed — central hub with four worker nodes
  distributed:
    '<circle cx="12" cy="12" r="2.4" stroke-width="1.6"/><circle cx="5" cy="5" r="1.8" stroke-width="1.6"/><circle cx="19" cy="5" r="1.8" stroke-width="1.6"/><circle cx="5" cy="19" r="1.8" stroke-width="1.6"/><circle cx="19" cy="19" r="1.8" stroke-width="1.6"/><path d="M10.3 10.3 6.4 6.4M13.7 10.3 17.6 6.4M10.3 13.7 6.4 17.6M13.7 13.7 17.6 17.6" stroke-width="1.6"/>',
  // Warehouse / lakehouse — stacked storage layers
  warehouse:
    '<path d="M12 3 3 7l9 4 9-4-9-4Z" stroke-width="1.6"/><path d="M3 12l9 4 9-4M3 17l9 4 9-4" stroke-width="1.6"/>',
  // Orchestration — two sources transformed into one output (DAG)
  orchestration:
    '<rect x="3" y="3.5" width="5.5" height="5.5" rx="1.5" stroke-width="1.6"/><rect x="3" y="15" width="5.5" height="5.5" rx="1.5" stroke-width="1.6"/><rect x="15.5" y="9.25" width="5.5" height="5.5" rx="1.5" stroke-width="1.6"/><path d="M8.5 6.25h3a2 2 0 0 1 2 2v1.5M8.5 17.75h3a2 2 0 0 0 2-2v-1.5" stroke-width="1.6"/>',
  // Cloud — cloud-native infrastructure
  cloud:
    '<path d="M6.5 19h10a4 4 0 0 0 .8-7.92 5.5 5.5 0 0 0-10.6-1.16A3.75 3.75 0 0 0 6.5 19Z" stroke-width="1.6"/>',
  // AI / ML — processor chip
  ai: '<path d="M12 3v3M12 18v3M3 12h3M18 12h3" stroke-width="1.6"/><rect x="8" y="8" width="8" height="8" rx="2" stroke-width="1.6"/><circle cx="12" cy="12" r="1.4" stroke-width="1.6"/>',
};
---

<Section
  id="expertise"
  kicker="Core Architecture"
  title="The Engineering Stack"
  intro="The exact technical stack required to build bulletproof data ecosystems."
>
  <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      expertise.map((item) => (
        <div data-reveal>
          <GlowCard class="h-full" accentHover>
            <div class="flex items-start justify-between gap-4">
              <span class="grid size-12 place-items-center rounded-xl border border-border bg-surface-3 text-accent transition-colors group-hover/glow:border-accent/40">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="size-6"
                  set:html={glyphs[item.icon]}
                />
              </span>
            </div>
            <h3 class="mt-5 text-xl font-semibold">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{item.blurb}</p>
            <ul class="mt-4 flex flex-wrap gap-1.5">
              {item.skills.map((s) => (
                <li class="rounded-md bg-surface-3 px-2 py-1 font-mono text-[11px] text-faint">
                  {s}
                </li>
              ))}
            </ul>
          </GlowCard>
        </div>
      ))
    }
  </div>
</Section>
