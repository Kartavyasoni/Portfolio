---
import Section from '@/components/ui/Section.astro';
import Button from '@/components/ui/Button.astro';
import { timeline, type TimelineKind } from '@/data/timeline';

// Show the compact preview in this order: experience, education, leadership.
const previewOrder: TimelineKind[] = ['experience', 'education', 'leadership'];
const entries = timeline
  .filter((e) => e.featured)
  .sort((a, b) => previewOrder.indexOf(a.kind) - previewOrder.indexOf(b.kind));

const kindStyles: Record<TimelineKind, { dot: string; label: string }> = {
  education: { dot: 'bg-cyan-400', label: 'Education' },
  experience: { dot: 'bg-accent', label: 'Experience' },
  leadership: { dot: 'bg-violet-400', label: 'Leadership' },
};
---

<Section
  id="journey"
  kicker="The Journey"
  title="A path through data and systems"
  intro="Experience, education, and leadership — the compact version."
>
  <div class="mt-14 grid gap-12 lg:grid-cols-[1fr_auto] lg:items-start">
    <ol class="relative ml-3 border-l border-border">
      {
        entries.map((entry) => {
          const style = kindStyles[entry.kind];
          return (
            <li class="relative ml-8 pb-10 last:pb-0" data-reveal>
              <span
                class={`absolute -left-[2.6rem] top-1 grid size-5 place-items-center rounded-full border border-border bg-surface`}
              >
                <span class={`size-2 rounded-full ${style.dot}`} />
              </span>
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <span class="font-mono text-xs uppercase tracking-wider text-accent">
                  {style.label}
                </span>
                <span class="font-mono text-xs text-faint">{entry.period}</span>
              </div>
              <h3 class="mt-2 text-lg font-semibold">{entry.title}</h3>
              <p class="text-sm text-muted">{entry.org}</p>
              <p class="mt-2 max-w-xl text-sm leading-relaxed text-muted">
                {entry.summary}
              </p>
            </li>
          );
        })
      }
    </ol>

    <div class="lg:sticky lg:top-28" data-reveal>
      <Button href="/about" size="lg" icon="arrowRight">Explore Full Journey</Button>
    </div>
  </div>
</Section>
