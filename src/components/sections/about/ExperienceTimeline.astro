---
import Section from '@/components/ui/Section.astro';
import { timeline, type TimelineKind } from '@/data/timeline';

// Full chronological timeline of education + experience (leadership shown separately).
const entries = timeline.filter((e) => e.kind !== 'leadership');

const kindStyles: Record<TimelineKind, { dot: string; label: string }> = {
  education: { dot: 'bg-cyan-400', label: 'Education' },
  experience: { dot: 'bg-accent', label: 'Experience' },
  leadership: { dot: 'bg-violet-400', label: 'Leadership' },
};
---

<Section
  id="experience"
  kicker="Experience"
  title="Where I've built and learned"
  intro="Professional and academic milestones along the way."
>
  <ol class="mt-14 relative ml-3 border-l border-border">
    {
      entries.map((entry) => {
        const style = kindStyles[entry.kind];
        return (
          <li class="relative ml-8 pb-12 last:pb-0" data-reveal>
            <span class="absolute -left-[2.6rem] top-1 grid size-5 place-items-center rounded-full border border-border bg-surface">
              <span class={`size-2 rounded-full ${style.dot}`} />
            </span>
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
              <span class="font-mono text-xs uppercase tracking-wider text-accent">
                {style.label}
              </span>
              <span class="font-mono text-xs text-faint">{entry.period}</span>
            </div>
            <h3 class="mt-2 text-xl font-semibold">{entry.title}</h3>
            <p class="text-sm text-muted">{entry.org}</p>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted">
              {entry.summary}
            </p>
          </li>
        );
      })
    }
  </ol>
</Section>
