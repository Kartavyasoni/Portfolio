---
import Section from '@/components/ui/Section.astro';
import GlowCard from '@/components/ui/GlowCard.astro';
import { skillGroups } from '@/data/skills';
---

<Section
  id="skills"
  kicker="Toolkit"
  title="Skills, grouped by craft"
  intro="From ingestion to inference to interface — the tools I reach for, organized by where they live in a data system."
>
  <div class="mt-14 grid gap-5 lg:grid-cols-2">
    {
      skillGroups.map((group) => (
        <div data-reveal>
          <GlowCard class="h-full">
            <h3 class="text-lg font-semibold">{group.title}</h3>
            <p class="mt-1 text-sm text-muted">{group.caption}</p>
            <ul class="mt-6 flex flex-col gap-4">
              {group.skills.map((skill) => (
                <li>
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-text">{skill.name}</span>
                    <span class="font-mono text-xs text-faint">{skill.level}%</span>
                  </div>
                  <div class="mt-2 h-1.5 overflow-hidden rounded-full bg-surface-3">
                    <span
                      class="skill-bar block h-full rounded-full bg-gradient-to-r from-brand-500 to-cyan-400"
                      style={`width:0%`}
                      data-level={skill.level}
                    />
                  </div>
                </li>
              ))}
            </ul>
          </GlowCard>
        </div>
      ))
    }
  </div>
</Section>

<script>
  const bars = document.querySelectorAll<HTMLElement>('.skill-bar');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const fill = (bar: HTMLElement) => {
    const level = bar.dataset.level ?? '0';
    // A frame later so the transition animates from 0.
    requestAnimationFrame(() => (bar.style.width = `${level}%`));
  };

  if (prefersReduced) {
    bars.forEach((b) => (b.style.width = `${b.dataset.level ?? 0}%`));
  } else {
    bars.forEach((b) => (b.style.transition = 'width 1.1s cubic-bezier(0.16,1,0.3,1)'));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            fill(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.4 },
    );
    bars.forEach((b) => io.observe(b));
  }
</script>
