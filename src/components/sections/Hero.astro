---
import Container from '@/components/ui/Container.astro';
import HeroScene from '@/components/three/HeroScene';
import { site } from '@/lib/site';
---

<section
  class="hero-cinema relative flex min-h-[100svh] items-center overflow-hidden"
>
  <!-- 3D wireframe terrain (browser-only island) -->
  <div class="pointer-events-none absolute inset-0">
    <HeroScene client:only="react" />
  </div>

  <!-- Readability scrim: darkens behind the centered text -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(75% 68% at 50% 46%, rgba(5,7,10,0.82), rgba(5,7,10,0.2) 60%, transparent 78%)"
  >
  </div>

  <!-- Bottom fade into the themed page -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 h-48 bg-gradient-to-b from-transparent to-[var(--bg)]"
  >
  </div>

  <!-- Content -->
  <Container class="relative z-10 pt-28 pb-24">
    <div class="mx-auto flex max-w-4xl flex-col items-center text-center" data-hero>
      <!-- Availability badge -->
      <span
        class="inline-flex items-center gap-2.5 font-mono text-xs uppercase tracking-[0.2em] text-green-400"
        data-hero-item
      >
        <span class="relative flex size-2.5">
          <span
            class="absolute inline-flex size-full animate-ping rounded-full bg-green-400 opacity-75"
          ></span>
          <span class="relative inline-flex size-2.5 rounded-full bg-green-400"></span>
        </span>
        Open to work
      </span>

      <h1
        class="mt-7 bg-gradient-to-b from-cyan-300 via-white to-slate-400 bg-clip-text text-[clamp(2.5rem,7.5vw,5.25rem)] font-bold leading-[1.03] text-transparent"
        data-hero-item
      >
        Transforming Raw Data into Production-Ready Intelligence
      </h1>

      <p class="mt-7 max-w-2xl text-lg text-muted" data-hero-item>
        {site.subheadline}
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4" data-hero-item>
        <a
          href="/projects"
          class="inline-flex h-14 items-center justify-center rounded-lg bg-white px-8 text-sm font-semibold uppercase tracking-wide text-[#05070a] transition-all duration-300 ease-[var(--ease-out-expo)] hover:-translate-y-0.5 hover:shadow-[0_14px_44px_-10px_rgba(255,255,255,0.35)]"
        >
          View Projects
        </a>
        <a
          href="/about"
          class="inline-flex h-14 items-center justify-center rounded-lg border border-white/15 bg-white/[0.03] px-8 text-sm font-semibold uppercase tracking-wide text-text backdrop-blur-sm transition-all duration-300 ease-[var(--ease-out-expo)] hover:-translate-y-0.5 hover:border-white/25 hover:bg-white/[0.07]"
        >
          About Me
        </a>
      </div>
    </div>
  </Container>

  <!-- Scroll cue -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-6 flex justify-center"
    data-hero-item
  >
    <div class="flex flex-col items-center gap-2 text-faint">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em]">Scroll</span>
      <span class="h-10 w-px animate-pulse-glow bg-gradient-to-b from-accent to-transparent"
      ></span>
    </div>
  </div>
</section>

<style>
  /* Always-dark cinematic backdrop so the wireframe reads in both themes. */
  .hero-cinema {
    background: linear-gradient(180deg, #05070a 0%, #060912 55%, var(--bg) 100%);
    color: #e6edf3;
  }

  /* Hero intro — pure CSS (no JS dependency) to keep LCP fast. */
  @media (prefers-reduced-motion: no-preference) {
    [data-hero-item] {
      opacity: 0;
      animation: hero-in 0.8s var(--ease-out-expo) forwards;
    }
    [data-hero] > [data-hero-item]:nth-child(1) {
      animation-delay: 0.05s;
    }
    [data-hero] > [data-hero-item]:nth-child(2) {
      animation-delay: 0.16s;
    }
    [data-hero] > [data-hero-item]:nth-child(3) {
      animation-delay: 0.27s;
    }
    [data-hero] > [data-hero-item]:nth-child(4) {
      animation-delay: 0.38s;
    }
  }

  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>
