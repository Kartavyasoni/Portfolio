---
import '../styles/global.css';
import { site } from '@/lib/site';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  /** Path to an OG image relative to /public, or absolute URL. */
  image?: string;
  /** Hide the chrome (nav/footer) — used for fullscreen experiences. */
  bare?: boolean;
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  image = '/og/default.png',
  bare = false,
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} · ${site.name}` : `${site.name} — ${site.role}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? site.url).href;
const ogImage = new URL(image, Astro.site ?? site.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={site.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#05070a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f7f9fc" media="(prefers-color-scheme: light)" />

    <!-- No-FOUC theme init: runs before first paint -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const system = matchMedia('(prefers-color-scheme: light)').matches
          ? 'light'
          : 'dark';
        const theme = stored ?? system;
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    {!bare && <Navbar />}
    <main id="main">
      <slot />
    </main>
    {!bare && <Footer />}
  </body>
</html>
