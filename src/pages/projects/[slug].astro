---
import { render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import GlowCard from '@/components/ui/GlowCard.astro';
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';
import Icon from '@/components/ui/Icon.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import {
  getProjects,
  getRelatedProjects,
  categoryAccent,
  accentGradient,
} from '@/lib/projects';

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);
const related = await getRelatedProjects(project, 2);
const accent = categoryAccent[data.category] ?? 'blue';
---

<Layout title={data.title} description={data.description}>
  <article>
    <!-- Hero -->
    <header class="relative overflow-hidden pt-32 pb-12 sm:pt-40">
      <div class="bg-grid pointer-events-none absolute inset-0 opacity-40"></div>
      <div
        class="glow-halo pointer-events-none absolute -top-1/4 left-1/3 size-[40vw] max-w-xl opacity-40"
      >
      </div>
      <Container class="relative">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 font-mono text-xs text-muted transition-colors hover:text-text"
        >
          <Icon name="arrowRight" class="size-3.5 rotate-180" />
          All Projects
        </a>

        <div class="mt-6 flex flex-wrap items-center gap-2">
          <Badge variant="accent">{data.category}</Badge>
          {data.tags.map((tag) => <Badge>{tag}</Badge>)}
        </div>

        <h1 class="mt-5 max-w-3xl text-[clamp(2rem,5vw,3.5rem)] font-semibold leading-[1.05]">
          {data.title}
        </h1>
        <p class="mt-5 max-w-2xl text-lg text-muted">{data.description}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          {
            data.github && (
              <Button href={data.github} variant="secondary" icon="github" rel="noopener noreferrer" target="_blank">
                View Source
              </Button>
            )
          }
          {
            data.demo && (
              <Button href={data.demo} variant="secondary" icon="external" rel="noopener noreferrer" target="_blank">
                Live Demo
              </Button>
            )
          }
        </div>
      </Container>
    </header>

    <!-- Visual band -->
    <Container>
      <div
        class="relative h-56 overflow-hidden rounded-[var(--radius-card)] border border-border sm:h-80"
      >
        <div class={`absolute inset-0 bg-gradient-to-br ${accentGradient[accent]}`}></div>
        <div class="bg-grid absolute inset-0 opacity-40"></div>
        <svg
          class="absolute inset-0 h-full w-full text-accent/60"
          viewBox="0 0 1200 400"
          fill="none"
          stroke="currentColor"
          preserveAspectRatio="xMidYMid slice"
        >
          <path d="M100 200h220M460 200h280M880 200h220" stroke-width="2" stroke-dasharray="6 10">
            <animate attributeName="stroke-dashoffset" from="32" to="0" dur="1.4s" repeatCount="indefinite"></animate>
          </path>
          <rect x="320" y="150" width="140" height="100" rx="14" stroke-width="2"></rect>
          <rect x="740" y="150" width="140" height="100" rx="14" stroke-width="2"></rect>
          <circle cx="100" cy="200" r="10" fill="currentColor"></circle>
          <circle cx="1100" cy="200" r="10" fill="currentColor"></circle>
        </svg>
      </div>
    </Container>

    <!-- Body: case study + sidebar -->
    <Container class="py-16 sm:py-20">
      <div class="grid gap-12 lg:grid-cols-[1fr_18rem] lg:items-start lg:gap-16">
        <div class="min-w-0">
          <!-- Problem -->
          <div data-reveal>
            <span class="kicker">The Problem</span>
            <p class="mt-3 text-lg leading-relaxed text-muted">{data.problem}</p>
          </div>

          <!-- Solution -->
          <div class="mt-12" data-reveal>
            <span class="kicker">The Solution</span>
            <p class="mt-3 text-lg leading-relaxed text-muted">{data.solution}</p>
          </div>

          <!-- Architecture -->
          {
            data.architecture && (
              <div class="mt-12" data-reveal>
                <span class="kicker">System Architecture</span>
                <div class="mt-4 rounded-[var(--radius-card)] border border-border bg-surface-2/50 p-6">
                  <p class="font-mono text-sm leading-relaxed text-muted">
                    {data.architecture}
                  </p>
                </div>
              </div>
            )
          }

          <!-- Deep-dive MDX content -->
          <div class="prose mt-12 max-w-none" data-reveal>
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="flex flex-col gap-5 lg:sticky lg:top-28">
          <GlowCard noLift>
            <span class="kicker">Tech Stack</span>
            <ul class="mt-4 flex flex-wrap gap-1.5">
              {
                data.techStack.map((t) => (
                  <li class="rounded-md border border-border bg-surface-3 px-2 py-1 font-mono text-[11px] text-faint">
                    {t}
                  </li>
                ))
              }
            </ul>
          </GlowCard>

          {
            data.results.length > 0 && (
              <GlowCard noLift>
                <span class="kicker">Results &amp; Impact</span>
                <ul class="mt-4 flex flex-col gap-3">
                  {data.results.map((r) => (
                    <li class="flex gap-2.5 text-sm text-muted">
                      <Icon name="arrowUpRight" class="mt-0.5 size-4 shrink-0 text-accent" />
                      <span>{r}</span>
                    </li>
                  ))}
                </ul>
              </GlowCard>
            )
          }
        </aside>
      </div>
    </Container>

    <!-- Related -->
    {
      related.length > 0 && (
        <Section kicker="Keep Exploring" title="Related projects">
          <div class="mt-12 grid gap-5 md:grid-cols-2">
            {related.map((p) => (
              <div data-reveal>
                <ProjectCard project={p} />
              </div>
            ))}
          </div>
        </Section>
      )
    }
  </article>
</Layout>
